{
  "name": "cam-road-map",
  "version": "0.1.0",
  "private": true,
  "description": "Web app mapping Cambodia's road network and administrative boundaries with development status.",
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
