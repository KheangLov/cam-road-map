    "data:boundaries": "node pipeline/build-boundaries.mjs",
    "data:tiles": "node pipeline/build-tiles.mjs",
    "data:all": "node pipeline/build-all.mjs"
  },
  "dependencies": {
    "maplibre-gl": "^4.7.1",
    "pmtiles": "^3.2.1"
  },
  "devDependencies": {
    "@nuxt/eslint": "^0.7.2",
    "@types/node": "^22.10.1",
    "eslint": "^9.16.0",
    "nuxt": "^3.14.1592",
    "sass": "^1.83.0",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.1.10"
  }
