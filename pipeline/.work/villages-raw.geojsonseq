{"type":"Feature","geometry":{"type":"Point","coordinates":[103.6762396,13.6644477]},"properties":{"addr:city":"Kok Chan, Ta Saom, Angkor Chum, Siem Reap","alt_name":"Phum Kauk Tchan, Phum Kok Tchan","description":"The site of a modern village that appears to be have been inhabited since ancient times, as the village resembles a circular village surrounded by what appears to be a moat. There is a small Neak Ta Phum Kok Chan shrine within the village which houses a n","name":"Phum Kok Chan   (Ancient Village)","name:km":"ភូមិគោកចាន់","note":"13.66444, 103.67625\nPart of\tPhum Kok Chan","place":"village"}}
